# =============================================================================
# TCRpredictor Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables with default values are shown after the '=' sign.
# Variables left blank are optional or require user-specific configuration.

# =============================================================================
# API Gateway (port 8000)
# =============================================================================
DATABASE_PATH=data/imgt.db
IMGT_DB_PATH=./imgt.db
IMGT_API_URL=http://127.0.0.1:8000

# =============================================================================
# Tool Servers
# =============================================================================
HLA_SERVER_URL=http://localhost:8101
TCR_SERVER_URL=http://localhost:8102
VDJDB_SERVER_URL=http://localhost:8103
IEDB_SERVER_URL=http://localhost:8104
BATMAN_SERVER_URL=http://localhost:8105
TEMPO_SERVER_URL=http://localhost:8106
MHC_SERVER_URL=http://127.0.0.1:8105

# --- Tool Server Feature Flags ---
BATMAN_ENABLE=true
BATMAN_TIMEOUT=30.0
TEMPO_ENABLE=true
TEMPO_TIMEOUT=30.0

# --- Tool Server Data Files ---
HLA_DATA_FILE=examples/hla_seed.csv
TCR_DATA_FILE=examples/tcr_seed.csv
VDJDB_DATA_FILE=examples/vdjdb_seed.csv

# =============================================================================
# External APIs
# =============================================================================
NCBI_API_KEY=                       # Optional, increases rate limit to 10 req/s
EBI_HLA_API_URL=https://www.ebi.ac.uk/cgi-bin/ipd/api/allele
EBI_MHC_API_URL=https://www.ebi.ac.uk/cgi-bin/ipd/api/allele
VDJDB_API_URL=https://vdjdb.cdr3.net/api/database/search
VDJDB_API_BASE=https://vdjdb.cdr3.net
IEDB_API_URL=https://query-api.iedb.org/tcell_search

# =============================================================================
# ML Model Serving — Tier 1 (port 8110)
# =============================================================================
TIER1_SERVER_URL=http://localhost:8110
TIER1_CHECKPOINT_PATH=              # Absolute path to best_model.pt (empty = stub mode)
TIER1_DEVICE=auto                   # auto, cuda, cpu, mps

# =============================================================================
# Deep Scoring — Tier 2
# =============================================================================
TIER2_TIMEOUT=10                    # Per-component timeout in seconds

# --- BATMAN Scoring ---
BATMAN_CACHE_DIR=./batman_cache
BATMAN_STEPS=20000
BATMAN_RAM_MODELS=50

# --- Tier 2 Baselines ---
PMTNET_SERVER_URL=                  # pMTnet Omni endpoint (empty = skip)
MIXTCRPRED_SERVER_URL=              # MixTCRpred endpoint (empty = skip)

# =============================================================================
# Structural Validation — Tier 3 (port 8120)
# =============================================================================
STRUCTURAL_SERVER_URL=http://localhost:8120
TCRMODEL2_SERVER_URL=               # Required for Tier 3 Step 1
TFOLD_SERVER_URL=                   # Required for Tier 3 Step 2
AF3_SERVER_URL=                     # Required for Tier 3 Step 3
AF3_MODE=server                     # server or local

# --- Structural Thresholds ---
STRUCTURAL_PLDDT_THRESHOLD=70.0     # Min pLDDT to promote TCRmodel2 -> tFold
STRUCTURAL_AF3_THRESHOLD=0.8        # Min composite score to promote to AF3

# =============================================================================
# LM Studio (NL Query)
# =============================================================================
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# =============================================================================
# Dashboard (Streamlit)
# =============================================================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# =============================================================================
# Experiment Tracking
# =============================================================================
WANDB_API_KEY=                      # Optional, for W&B experiment tracking
WANDB_PROJECT=tcrpredictor

# =============================================================================
# DVC Remote (Data Version Control)
# =============================================================================
DVC_REMOTE=                         # s3://bucket/path or gs://bucket/path
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
