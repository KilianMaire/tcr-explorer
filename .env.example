# =============================================================================
# TCR Explorer Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables with default values are shown after the '=' sign.
# Variables left blank are optional or require user-specific configuration.

# =============================================================================
# API Gateway (port 8000)
# =============================================================================
IMGT_API_URL=http://127.0.0.1:8000

# =============================================================================
# Tool Servers (optional live enrichment for hla/mhc allele sequences)
# =============================================================================
HLA_SERVER_URL=http://localhost:8101
MHC_SERVER_URL=http://127.0.0.1:8105

# --- Tool Server Data Files ---
HLA_DATA_FILE=examples/hla_seed.csv

# =============================================================================
# External APIs (hla/mhc allele lookups)
# =============================================================================
EBI_HLA_API_URL=https://www.ebi.ac.uk/cgi-bin/ipd/api/allele
EBI_MHC_API_URL=https://www.ebi.ac.uk/cgi-bin/ipd/api/allele

# =============================================================================
# TCR Similarity
# =============================================================================
UNITCR_INDEX_PATH=                  # Override path to the vendored uniTCR reference index parquet (empty = built-in default)
RECORDS_INDEX_PATH=                 # Override path to the harmonized multi-source records index parquet (empty = built-in default)

# =============================================================================
# Agnostic LLM Client (optional, graceful; powers the conversational ask path)
# =============================================================================
LLM_BASE_URL=                       # OpenAI-compatible base URL (empty = disabled)
LLM_MODEL=local-model               # Model name passed to /chat/completions
LLM_API_KEY=                        # Optional bearer token
LLM_TIMEOUT=8.0                     # Request timeout in seconds
LLM_ENABLE=true                     # Set to false to force-disable even if base URL is set

# =============================================================================
# Dashboard (Streamlit, ui-legacy extra)
# =============================================================================
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# Local data directory for downloaded datasets (default: platformdirs user data dir)
TCR_EXPLORER_DATA=
# Max age in days before the records index is flagged stale (default: 30)
TCR_EXPLORER_MAX_AGE_DAYS=
# Timeout in seconds for the opt-in `--germline` IMGT download (default: 600)
TCR_EXPLORER_STITCHRDL_TIMEOUT=
# Set (to any value) to mark this instance as a public germline-only demo: the
# /ui shows a banner explaining that record databases are not served here.
TCR_EXPLORER_DEMO=
